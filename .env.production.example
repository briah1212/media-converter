# =============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.production and update with your production values
# IMPORTANT: Never commit .env.production to version control
# =============================================================================

# -----------------------------------------------------------------------------
# BACKEND CONFIGURATION
# -----------------------------------------------------------------------------

# Host binding - use 0.0.0.0 to accept connections from all interfaces
BACKEND_HOST=0.0.0.0

# Backend port - default 8000 (proxied by Nginx/Caddy)
BACKEND_PORT=8000

# Number of worker processes (recommended: number of CPU cores)
BACKEND_WORKERS=4

# Disable auto-reload in production for stability
BACKEND_RELOAD=false

# -----------------------------------------------------------------------------
# FRONTEND CONFIGURATION
# -----------------------------------------------------------------------------

# API URL - must match your production domain
# Examples:
#   - https://yourdomain.com/api
#   - https://convert.yourdomain.com/api
VITE_API_URL=https://yourdomain.com/api

# -----------------------------------------------------------------------------
# SECURITY SETTINGS
# -----------------------------------------------------------------------------

# Secret key for session management and JWT tokens
# CRITICAL: Generate a secure random key (minimum 32 characters)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS

# CORS origins - comma-separated list of allowed origins
# Examples:
#   - Single domain: https://yourdomain.com
#   - Multiple domains: https://yourdomain.com,https://www.yourdomain.com
#   - Subdomain: https://convert.yourdomain.com
CORS_ORIGINS=https://yourdomain.com

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# -----------------------------------------------------------------------------
# FILE UPLOAD LIMITS
# -----------------------------------------------------------------------------

# Maximum upload size in bytes
# Examples:
#   - 100MB: 104857600
#   - 500MB: 524288000
#   - 1GB:   1073741824
#   - 2GB:   2147483648
MAX_UPLOAD_SIZE=524288000

# Temporary upload directory (must be writable by application)
UPLOAD_DIR=/tmp/media-converter-uploads

# Converted files directory (must be writable by application)
CONVERTED_DIR=/tmp/media-converter-converted

# File retention time in seconds (default: 1 hour = 3600)
FILE_RETENTION_SECONDS=3600

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------

# Enable/disable rate limiting (true/false)
RATE_LIMIT_ENABLED=true

# Maximum requests per time window
RATE_LIMIT_REQUESTS=30

# Time window in seconds
RATE_LIMIT_WINDOW=60

# Rate limit storage (memory/redis)
RATE_LIMIT_STORAGE=memory

# Redis connection (if using redis for rate limiting)
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# LOGGING CONFIGURATION
# -----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Production recommendation: INFO or WARNING
LOG_LEVEL=INFO

# Log file path (ensure directory exists and is writable)
LOG_FILE=/var/log/media-converter/app.log

# Log format: json, text
LOG_FORMAT=json

# Enable request logging (true/false)
LOG_REQUESTS=true

# -----------------------------------------------------------------------------
# FFMPEG CONFIGURATION
# -----------------------------------------------------------------------------

# FFmpeg binary path (leave empty to use system PATH)
FFMPEG_PATH=

# FFprobe binary path (leave empty to use system PATH)
FFPROBE_PATH=

# FFmpeg timeout in seconds (per conversion)
FFMPEG_TIMEOUT=300

# Maximum concurrent conversions
MAX_CONCURRENT_CONVERSIONS=2

# -----------------------------------------------------------------------------
# DATABASE (Optional - for future features)
# -----------------------------------------------------------------------------

# Database URL (uncomment if using database)
# DATABASE_URL=postgresql://user:password@localhost:5432/mediaconverter

# -----------------------------------------------------------------------------
# EMAIL NOTIFICATIONS (Optional - for future features)
# -----------------------------------------------------------------------------

# SMTP configuration for email notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# MONITORING & METRICS (Optional)
# -----------------------------------------------------------------------------

# Enable Prometheus metrics endpoint (true/false)
# ENABLE_METRICS=true
# METRICS_PORT=9090

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# -----------------------------------------------------------------------------
# PERFORMANCE TUNING
# -----------------------------------------------------------------------------

# Enable gzip compression (true/false)
ENABLE_GZIP=true

# Compression level (1-9, where 9 is maximum compression)
GZIP_LEVEL=6

# Enable response caching (true/false)
ENABLE_CACHE=true

# Cache TTL in seconds
CACHE_TTL=300

# -----------------------------------------------------------------------------
# DOCKER SPECIFIC (if using Docker)
# -----------------------------------------------------------------------------

# Docker network name
DOCKER_NETWORK=media-converter-network

# Container names
BACKEND_CONTAINER_NAME=media-converter-backend
FRONTEND_CONTAINER_NAME=media-converter-frontend

# -----------------------------------------------------------------------------
# SECURITY HEADERS (handled by reverse proxy, documented here)
# -----------------------------------------------------------------------------

# These are typically configured in Nginx/Caddy, not in application env vars
# Reference values:
#   - Strict-Transport-Security: max-age=31536000; includeSubDomains
#   - X-Content-Type-Options: nosniff
#   - X-Frame-Options: DENY
#   - X-XSS-Protection: 1; mode=block
#   - Content-Security-Policy: default-src 'self'

# -----------------------------------------------------------------------------
# PRODUCTION CHECKLIST
# -----------------------------------------------------------------------------

# Before deploying to production, ensure:
# [ ] SECRET_KEY is changed to a secure random value
# [ ] CORS_ORIGINS matches your production domain
# [ ] VITE_API_URL matches your production API endpoint
# [ ] LOG_LEVEL is set to INFO or WARNING
# [ ] File upload limits are appropriate for your use case
# [ ] Rate limiting is configured appropriately
# [ ] Log directories exist and are writable
# [ ] Temporary directories exist and are writable
# [ ] File permissions on .env.production are set to 600
# [ ] .env.production is added to .gitignore
# [ ] SSL/TLS certificates are configured
# [ ] Reverse proxy (Nginx/Caddy) is configured
# [ ] Firewall rules are configured
# [ ] Backup strategy is in place

