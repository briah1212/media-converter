# Vercel Environment Variables Configuration
# Copy this file to .env.local for local development

# =============================================================================
# API Configuration
# =============================================================================

# Backend API URL
# For local development: http://localhost:8000
# For production: https://your-backend-domain.com (Railway, Render, or Fly.io)
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# Vercel Deployment Instructions
# =============================================================================
#
# 1. In Vercel Dashboard:
#    - Go to Project Settings > Environment Variables
#    - Add the following variable:
#
#    Name: NEXT_PUBLIC_API_URL
#    Value: https://your-backend-domain.com
#    Environments: Production, Preview, Development (select as needed)
#
# 2. For different environments:
#    - Production: Use your production backend URL
#    - Preview: Use staging backend URL (optional)
#    - Development: Can use localhost or a dev backend
#
# 3. Important Notes:
#    - Variables starting with NEXT_PUBLIC_ are exposed to the browser
#    - Changes to environment variables require a new deployment
#    - Use Vercel CLI to set secrets: vercel env add NEXT_PUBLIC_API_URL
#
# =============================================================================
# Backend Hosting Options
# =============================================================================
#
# Railway: https://railway.app (recommended for free tier)
#   - Deploy backend directly from GitHub
#   - /month credit on free tier
#   - Example: https://media-converter-backend.railway.app
#
# Render: https://render.com
#   - Free tier available with 750 hours/month
#   - Auto-sleep after 15 minutes of inactivity
#   - Example: https://media-converter-backend.onrender.com
#
# Fly.io: https://fly.io
#   - Free tier: 3 shared-cpu VMs
#   - Better performance than Render free tier
#   - Example: https://media-converter-backend.fly.dev
#
# =============================================================================
